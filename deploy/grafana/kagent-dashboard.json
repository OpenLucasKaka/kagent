{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": {
          "type": "grafana",
          "uid": "-- Grafana --"
        },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 0,
        "y": 0
      },
      "id": 1,
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "textMode": "auto"
      },
      "targets": [
        {
          "expr": "up{job=\"kagent\"}",
          "legendFormat": "{{instance}}",
          "refId": "A"
        }
      ],
      "title": "Service Health",
      "type": "stat"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 6,
        "y": 0
      },
      "id": 2,
      "targets": [
        {
          "expr": "sum(rate(kagent_responses_total{status=~\"5..\"}[5m])) / clamp_min(sum(rate(kagent_requests_total[5m])), 1)",
          "legendFormat": "5xx rate",
          "refId": "A"
        }
      ],
      "title": "HTTP 5xx Rate",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 12,
        "y": 0
      },
      "id": 3,
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(kagent_runtime_run_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "p95",
          "refId": "A"
        }
      ],
      "title": "Runtime p95 Latency",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ops"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 18,
        "y": 0
      },
      "id": 4,
      "targets": [
        {
          "expr": "sum(rate(kagent_runtime_approval_required_total[5m]))",
          "legendFormat": "approvals",
          "refId": "A"
        }
      ],
      "title": "Runtime Approval Pressure",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ops"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 4,
        "w": 12,
        "x": 0,
        "y": 20
      },
      "id": 10,
      "targets": [
        {
          "expr": "sum(rate(kagent_runtime_progress_event_sink_failures_total[5m]))",
          "legendFormat": "sink failures",
          "refId": "A"
        }
      ],
      "title": "Runtime Progress Sink Failures",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 4,
        "w": 12,
        "x": 12,
        "y": 20
      },
      "id": 9,
      "targets": [
        {
          "expr": "sum(kagent_runtime_stale_pending_approvals_current)",
          "legendFormat": "stale pending approvals",
          "refId": "A"
        },
        {
          "expr": "max(kagent_runtime_max_pending_approval_age_seconds)",
          "legendFormat": "max pending age seconds",
          "refId": "B"
        }
      ],
      "title": "Runtime Stale Pending Approvals",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ops"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 0,
        "y": 4
      },
      "id": 5,
      "targets": [
        {
          "expr": "sum by (auth_subject) (rate(kagent_runtime_runs_by_auth_subject_total[5m]))",
          "legendFormat": "{{auth_subject}}",
          "refId": "A"
        }
      ],
      "title": "Runtime Runs by Subject",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ops"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 8,
        "y": 4
      },
      "id": 6,
      "targets": [
        {
          "expr": "sum by (auth_subject, status) (rate(kagent_runtime_run_status_by_auth_subject_total[5m]))",
          "legendFormat": "{{auth_subject}} {{status}}",
          "refId": "A"
        }
      ],
      "title": "Runtime Outcomes by Subject",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ops"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 16,
        "y": 4
      },
      "id": 7,
      "targets": [
        {
          "expr": "sum by (auth_subject) (rate(kagent_runtime_resumes_by_auth_subject_total[5m]))",
          "legendFormat": "{{auth_subject}}",
          "refId": "A"
        }
      ],
      "title": "Runtime Resumes by Subject",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ops"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 12
      },
      "id": 8,
      "targets": [
        {
          "expr": "sum by (error_code) (rate(kagent_runtime_observation_errors_total[5m]))",
          "legendFormat": "{{error_code}}",
          "refId": "A"
        }
      ],
      "title": "Runtime Tool Errors",
      "type": "timeseries"
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": [
    "SelfCorrectingAgent",
    "LangGraph",
    "Runtime"
  ],
  "templating": {
    "list": [
